{
	"name": "n8n-nodes-merge",
	"version": "0.2.9",
	"description": "n8n community nodes for Merge - connect AI agents to Merge Tool Packs via Agent Handler and use any LLM provider via Merge Gateway chat models",
	"license": "MIT",
	"homepage": "https://github.com/merge-api/n8n-nodes-merge#readme",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Merge",
		"email": "experience@merge.dev"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/merge-api/n8n-nodes-merge.git"
	},
	"scripts": {
		"build": "tsc && node scripts/postbuild.js",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"aiNodeSdkVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/MergeAgentHandlerApi.credentials.js",
			"dist/credentials/MergeGatewayApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/MergeAgentHandlerTools/MergeAgentHandlerTools.node.js",
			"dist/nodes/MergeAgentHandler/MergeAgentHandler.node.js",
			"dist/nodes/MergeGatewayChatModel/MergeGatewayChatModel.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.23.0",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"@n8n/ai-node-sdk": "*",
		"n8n-workflow": "*"
	}
}
